ADMIN_API_KEY=changeme_admin_api_key
MASTER_ENCRYPTION_KEY=32_byte_base64_or_hex_key_here
# For production: use a KMS to supply the key. See README for examples.
PORT=4000

# Seed admin user (for feature/cps-admin-auth branch)
# CPS_ADMIN_USER=admin
# CPS_ADMIN_PASSWORD_HASH= (bcrypt hash) or leave blank to create via migration
ADMIN_INIT_USERNAME=admin
ADMIN_INIT_PASSWORD=change-me-locally
ADMIN_JWT_SECRET=change-me-jwt-secret

# Optional: allow overriding storage via DATABASE_URL
# DATABASE_URL=sqlite://./cps_metadata.db
