{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
  "outDir": "dist",
  "rootDir": ".",
    "moduleResolution": "node",
    "typeRoots": ["./src/types", "./node_modules/@types"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules"]
}
